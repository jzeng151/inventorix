{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Inventorix",
  "version": "0.1.0",
  "identifier": "com.inventorix.app",
  "build": {
    "frontendDist": "http://localhost:3000",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cargo run --bin inventorix-server"
  },
  "app": {
    "windows": [
      {
        "title": "Inventorix",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["mobile", "desktop"]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "app"],
    "icon": ["icons/icon.icns", "icons/icon.ico", "icons/icon.png"],
    "windows": {
      "wix": {}
    }
  }
}
