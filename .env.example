# Inventorix — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# --- Required ---

# Path to the SQLite database file
# Windows production: C:\Inventorix\data\inventorix.db
DB_PATH=./inventorix.db

# Secret key for signing session cookies (min 32 bytes, generate with: openssl rand -hex 32)
SESSION_SECRET=replace-with-a-random-32-byte-hex-string

# Salesforce integration mode
# mock: records calls in memory, no real Salesforce calls (use for all local dev and tests)
# live: makes real Salesforce API calls (production only)
SALESFORCE_MODE=mock

# --- Salesforce (required only when SALESFORCE_MODE=live) ---

SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=https://company.my.salesforce.com

# --- Optional ---

# HTTP port for the Axum server (default: 3000)
PORT=3000

# Directory for daily SQLite backups (default: ./backups)
BACKUP_DIR=./backups

# Log level: error, warn, info, debug, trace (default: info)
RUST_LOG=info
